{
  "name": "scholarly",
  "version": "1.0.18",
  "description": "A library to query and parse academic articles from Google Scholar",
  "main": "./dist/index.js",
  "scripts": {
    "test": "jest",
    "clean": "rimraf dist coverage",
    "lint": "eslint . --ext .ts --fix",
    "prebuild": "yarn lint && yarn test",
    "build": "yarn clean && tsc -p tsconfig.build.json",
    "tsc:w": "tsc -w",
    "prepack": "yarn build",
    "test:coverage": "jest --coverage",
    "report": "codecov"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukalwa/scholarly.git"
  },
  "keywords": [
    "google",
    "scholar",
    "publications",
    "research",
    "academic",
    "parser"
  ],
  "author": "Upender Kalwa",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ukalwa/scholarly/issues"
  },
  "homepage": "https://github.com/ukalwa/scholarly#readme",
  "devDependencies": {
    "@types/cheerio": "^0.22.18",
    "@types/jest": "^26.0.9",
    "@typescript-eslint/eslint-plugin": "^3.9.0",
    "@typescript-eslint/parser": "^3.9.0",
    "codecov": "^3.6.5",
    "eslint": "^7.6.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.4",
    "jest": "^26.4.0",
    "prettier": "^2.0.5",
    "rimraf": "^3.0.2",
    "ts-jest": "^26.2.0",
    "ts-node": "^8.10.1",
    "typescript": "^3.9.7"
  },
  "dependencies": {
    "axios": "^0.19.2",
    "cheerio": "^1.0.0-rc.3"
  },
  "files": [
    "dist"
  ]
}
